{
  "name": "linkly",
  "version": "1.0.0",
  "description": "Uma API REST para encurtamento de URLs desenvolvida com **Node.js**, **Fastify** e **SQLite**.",
  "homepage": "https://github.com/daviacarvalho/linkly#readme",
  "bugs": {
    "url": "https://github.com/daviacarvalho/linkly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daviacarvalho/linkly.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/**/*.test.ts",
    "db:migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
